# ─── Auth.js (NextAuth) ──────────────────────────────────────────────
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Supabase ────────────────────────────────────────────────────────
# Server-only — never expose the service role key to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ─────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# Bearer secret required by POST /api/cron/poll. openssl rand -base64 32
CRON_SECRET=
# 32-byte base64 key that encrypts stored refresh tokens. openssl rand -base64 32
TOKEN_ENC_KEY=

# ─── Branding & scope (see app/lib/config.ts) ────────────────────────
# Restrict dashboard login to one email domain, e.g. acme.com (empty = any Google account).
COMPANY_EMAIL_DOMAIN=
# Product/brand name shown in the UI and emails (must be NEXT_PUBLIC_ to reach the browser).
NEXT_PUBLIC_APP_NAME=Demo Feedback
